# This file contains configurations common to both Bash and Zsh.
# It is sourced by .bashrc and, if zsh is installed, by .zshrc as well.
# shellcheck shell=bash

if command -v zellij >/dev/null 2>&1 && [[ $- == *i* ]] && [[ -z "${ZELLIJ}" ]] && [[ -z "${SSH_TTY}" ]] && [[ -z "${SSH_CLIENT}" ]]; then
    zellij
fi

if [[ -f "$HOME/.raku/bin/s6" ]]; then
    export SP6_REPO=https://sparrowhub.io/repo
fi

if command -v npm > /dev/null 2>&1; then
    npm_prefix="$HOME/.npm-global"
    mkdir -p "$npm_prefix"
    if [[ "$(npm config get prefix)" != "$npm_prefix" ]]; then
        npm config set prefix "$npm_prefix"
    fi
    unset npm_prefix
fi

# Add user-specific directories to PATH if they exist
_dirs_to_prepend=(
    "$HOME/.local/bin"
    "$HOME/bin"
    "$HOME/go/bin"
    "$HOME/.luarocks/bin"
    "$HOME/.raku/bin"
    "$HOME/.cargo/bin"
    "$HOME/.dotnet/tools"
    "$HOME/.npm-global/bin"
)

# Ruby gems: path varies by version, pick the first match
if [[ -d "$HOME/.local/share/gem/ruby" ]]; then
    for _gemdir in "$HOME/.local/share/gem/ruby/"*/bin; do
        if [[ -d "$_gemdir" ]]; then
            _dirs_to_prepend+=("$_gemdir")
            break
        fi
    done
    unset _gemdir
fi

for _dir in "${_dirs_to_prepend[@]}"; do
    if [[ -d "$_dir" ]]; then
        export PATH="$_dir:$PATH"
    fi
done
unset _dir _dirs_to_prepend

if [[ -f "$HOME/.config/ripgrep/ripgreprc" ]]; then
    export RIPGREP_CONFIG_PATH="$HOME/.config/ripgrep/ripgreprc"
fi

export OLLAMA_API_BASE="http://127.0.0.1:11434"

log_system() {
    (
        local log_path=$HOME/.cache/ditana
        local temp1="$log_path/systemd.log"
        local temp2="$log_path/dmesg.log"
        mkdir -p "$log_path"

        journalctl --priority=5 --follow --catalog --no-hostname &>"$temp1" &
        local log_systemd_pid=$!

        sudo bash << EOF
dmesg --human --color --reltime --nopager --level=warn --follow > '$temp2' &
echo \$! > /tmp/dmesg_pid
EOF

        local log_dmesg_pid=$(sudo cat /tmp/dmesg_pid)
        sudo /bin/rm /tmp/dmesg_pid

        # shellcheck disable=SC2064
        trap "kill $log_systemd_pid; sudo kill $log_dmesg_pid; sudo rm '$temp1' '$temp2'" SIGINT SIGTERM

        tail -Fv "$temp1" "$temp2" /var/log/pacman.log /var/log/Xorg.0.log
    )
}

safe_rm() {
    for arg in "$@"; do
        if [[ -e "$arg" || -L "$arg" ]]; then
            if [[ "$(realpath -- "$arg")" == "$(realpath -- "$HOME")" ]]; then
                echo "Prevented deleting your home directory. In case you really want to, please use /bin/rm." >&2
                return 1
            fi
        elif [[ "$arg" != -* ]]; then
            echo "Warning: '$arg' does not exist."
        fi
    done
    /bin/rm "$@"
}

get_package_installer() {
    local installers=(pikaur pakku aurman trizen paru yay pacman)
    for installer in "${installers[@]}"; do
        if command -v "$installer" > /dev/null 2>&1; then
            echo "$installer"
            return
        fi
    done
    echo "Error: No AUR helper or pacman found. This is meant for Arch-based systems." >&2
    return 1
}

_ditana_installer=$(get_package_installer)

alias rm=safe_rm
alias open='xdg-open &>/dev/null'
if command -v eza > /dev/null 2>&1; then
    alias ll='eza --long --icons --classify --hyperlink --group-directories-first'
fi

rm_orphaned() {
    local orphans
    orphans=$(pacman --query --unrequired --deps --quiet)
    if [[ -n "$orphans" ]]; then
        echo "Removing orphaned packages:" $orphans
        sudo pacman --remove --nosave --recursive $orphans
    else
        echo "No orphaned packages to remove."
    fi
}

if command -v inotifywait > /dev/null 2>&1; then
    alias monitor_dir='inotifywait -m -r -e modify -e create -e delete'
fi

# shellcheck disable=SC2139
if [[ -n "$_ditana_installer" ]]; then
    alias addpkg="$_ditana_installer -Syu"
    alias rmpkg="$_ditana_installer -Rsu"
fi
unset _ditana_installer

# Show parent process of current shell
pp() {
    local ppid
    ppid=$(ps -o ppid= -p $$ | xargs)
    ps -o comm= -p "$ppid"
}

# System info display
if command -v print-system-infos > /dev/null 2>&1; then
    bash /usr/bin/print-system-infos # provided by package ditana-print-system-infos. Contains bash-specific syntax.
elif command -v fastfetch > /dev/null 2>&1; then
    fastfetch
elif command -v neofetch > /dev/null 2>&1; then
    neofetch
fi

# OSC 133 semantic prompt markers for the foot terminal.
#
# These escape sequences annotate the boundaries between prompt,
# user-entered command, and command output. Foot uses them to enable
# jump-to-prompt navigation and single-click selection of a command's
# full output. Starship does not emit OSC 133 natively (upstream issue
# starship/starship#5463), so Ditana wires the hooks in here.
#
# Terminals that do not understand OSC 133 (alacritty, legacy xterm,
# GNOME Terminal, ...) silently ignore the sequences, so the guard
# below exists purely to avoid unnecessary escape traffic on systems
# where foot is not configured.
#
# The guard matches both a direct foot session ($TERM starts with
# "foot") and a foot session reached through a multiplexer that
# rewrites $TERM but preserves Ditana's $TERMINAL from /etc/environment.d
# (e.g., zellij running inside foot). In the multiplexer case, the
# outer foot still sees the sequences provided the multiplexer passes
# OSC through, which zellij does by default.
#
# Spec: https://gitlab.freedesktop.org/Per_Bothner/specifications/-/blob/master/proposals/semantic-prompts.md
if [[ "${TERM:-}" == foot* || "${TERMINAL:-}" == "foot" ]]; then
    __ditana_osc133_precmd() {
        # Must capture $? first, before any other command resets it.
        local exit_code=$?
        # D = previous command finished (with exit code),
        # A = next prompt starts.
        printf '\e]133;D;%s\a\e]133;A\a' "$exit_code"
        # Preserve exit code for subsequent hooks (e.g., starship's
        # status module relies on $? being the real command status).
        return $exit_code
    }

    if [[ -n "${ZSH_VERSION:-}" ]]; then
        __ditana_osc133_preexec() {
            # C = command about to execute.
            printf '\e]133;C\a'
        }
        # Prepend so our hook captures $? before any other precmd runs.
        precmd_functions=(__ditana_osc133_precmd $precmd_functions)
        preexec_functions+=(__ditana_osc133_preexec)
    elif [[ -n "${BASH_VERSION:-}" ]]; then
        # Prepend to PROMPT_COMMAND for the same reason.
        PROMPT_COMMAND="__ditana_osc133_precmd;${PROMPT_COMMAND:-}"
        # PS0 is emitted after the user hits Enter but before the
        # command runs — exactly OSC 133;C semantics. Requires bash
        # 4.4+, which is a given on Arch.
        PS0=$'\e]133;C\a'
    fi
fi

for config_file in "$HOME/.shell.d/"*; do
    # shellcheck disable=SC1090
    [[ -f "$config_file" ]] && [[ -x "$config_file" ]] && source "$config_file"
done
