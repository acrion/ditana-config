#!/usr/bin/env bash

# This script is executed by /usr/share/ditana/xsessions/xfce-ditana.desktop,
# whose directory is referenced by /etc/greetd/config.toml.

exec > >(systemd-cat -t ditana-pre-xfce-login -p info) 2>&1

export XDG_SESSION_TYPE=x11
export XDG_SESSION_DESKTOP=xfce
export XDG_CURRENT_DESKTOP=XFCE

while read -r line; do
    [[ -z "$line" ]] || [[ "${line:0:1}" = "#" ]] && continue
    export "${line?}"
done < <(/usr/lib/systemd/user-environment-generators/30-systemd-environment-d-generator)

dbus-update-activation-environment --systemd --all

# /usr/lib/ditana/session-setup is composed of the following kdl entries:
# - login-scripts
# - login-commands
# - first-login-scripts
# - first-login-commands
source /usr/lib/ditana/session-setup

env | sort

if systemctl --user is-active --quiet graphical-session.target; then
    echo ">>> WARNING: graphical-session.target is already active! <<<"
    echo "This indicates a flaw in the systemd user session lifecycle. A service pulled the target too early."
    echo "While startxfce4 won't abort, this can cause GUI services to fail because they start before the X server is ready."
    echo "Units configured to pull in graphical-session.target (reverse dependencies):"

    systemctl --user list-dependencies --reverse --plain --no-legend graphical-session.target 2>/dev/null | \
        sed '/^graphical-session.target$/d' | \
        while read -r unit; do
            if systemctl --user is-active --quiet "$unit"; then
                echo "  -> [ACTIVE]   $unit"
            else
                echo "  -> [INACTIVE] $unit"
            fi
        done || echo "  (unable to list dependencies)"

    echo ">>> End of pre-login diagnostic <<<"
fi

if [ -n "$XDG_VTNR" ]; then
    exec startxfce4 -- "vt$XDG_VTNR" -keeptty
else
    exec startxfce4
fi
