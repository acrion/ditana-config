#!/usr/bin/env bash

# This script is executed by /usr/share/ditana/wayland-sessions/wayfire-ditana.desktop,
# whose directory is referenced by /etc/greetd/config.toml.

{
    uwsm stop || true

    # /usr/lib/ditana/session-setup is composed of the following kdl entries:
    # - login-scripts
    # - login-commands
    # - first-login-scripts
    # - first-login-commands
    source /usr/lib/ditana/session-setup

    env | sort
} 2>&1 | systemd-cat -t ditana-pre-wayfire-login -p info

uwsm start wayfire.desktop
