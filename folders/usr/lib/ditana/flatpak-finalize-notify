#!/usr/bin/env bash
# Show notification at login about Flatpak finalize result.
# Called via login-commands. Runs in user context.

MARKER="$HOME/.config/ditana/flatpak-notification-shown"
STATUS_OK=/var/lib/ditana/flatpak-finalize.success
STATUS_FAIL=/var/lib/ditana/flatpak-finalize.failed

[ -f "$MARKER" ] && exit 0

command -v notify-send >/dev/null 2>&1 || exit 0

if [ -f "$STATUS_FAIL" ]; then
    failed=$(tr '\n' ', ' < "$STATUS_FAIL" | sed 's/, $//')
    notify-send -u critical -i dialog-warning \
        "Sandboxed apps: install failed" \
        "Failed: $failed. Run 'sudo systemctl start ditana-flatpak-finalize.service' to retry."
elif [ -f "$STATUS_OK" ]; then
    notify-send -u low -i dialog-information \
        "Sandboxed apps: ready" \
        "Your Flatpak applications were installed successfully during first boot."
    # Only mark as shown after success — we want to keep nagging on failure
    mkdir -p "$(dirname "$MARKER")"
    touch "$MARKER"
fi
