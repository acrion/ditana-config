- name="install-desktop-environment" \
  default-value="`install-xfce OR install-wayfire OR install-niri OR install-cosmic`" {
    arch-packages \ // === greetd ===
                  "greetd" \
                  "greetd-tuigreet" \
                  "uwsm" \
                  \ // === XDG utilities ===
                  "xdg-user-dirs" \
                  "xdg-utils" \
                  \ // === Key management ===
                  "seahorse" \
                  \ // === Bluetooth (GUI) ===
                  "blueman" \
                  \ // === Audio ===
                  "pavucontrol" \
                  \ // === Network tray ===
                  "network-manager-applet" \
                  \ // === Security updates indicator ===
                  "arch-audit-gtk" \
                  \ // === GPU diagnostics ===
                  "mesa-utils" \
                  "libva-utils" \
                  "intel-gpu-tools" \
                  \ // === System resources monitor ===
                  "resources" \
                  \ // === Disk management ===
                  "gnome-disk-utility" \
                  \ // === Printing ===
                  "system-config-printer" \
                  "cups-pk-helper" \
                  "python-pysmbc" \
                  \ // === Send Desktop Notifications ===
                  "libnotify" \
                  \ // === implement the secret portal, for certain apps to work ===
                  "gnome-keyring"
    files \ // Marker file for first-login detection. If this file exists when the user logs in,
          \ // session-setup scripts marked with once=true (see "session-setup" below) are executed,
          \ // and the file is then deleted. See generate-session-setup() in Chroot.rakumod.
          "/etc/skel/.config/ditana/trigger-first-login" \
          \ // === Greetd configuration ===
          "/etc/greetd/config.toml" \
          \ // XDG user dirs. The upstream /etc/xdg/autostart/xdg-user-dirs.desktop
          \ // sets X-systemd-skip=true and X-GNOME-Autostart-Phase=EarlyInitialization;
          \ // both keys cause systemd-xdg-autostart-generator to skip the entry (see
          \ // systemd-xdg-autostart-generator(8) and upstream issue systemd/systemd#18791).
          \ // As a result the upstream entry does not run on compositors that rely on
          \ // systemd for XDG autostart (Niri, Wayfire via graphical-session.target).
          \ // XFCE4 has its own autostart handler that ignores those keys, so the
          \ // upstream entry works there. We ship an additional entry without the skip
          \ // keys so xdg-user-dirs-update runs on every DE; it is idempotent, so
          \ // running twice on XFCE is harmless.
          "/etc/xdg/autostart/ditana-xdg-user-dirs.desktop" \
          \ // XDG Base Directory Specification defaults, set explicitly for visibility
          \ // and robustness against spec-nonconforming apps. environment.d covers
          \ // systemd user services and logind-started sessions; the matching
          \ // /etc/profile.d/ditana-xdg.sh below covers interactive login shells.
          "/etc/environment.d/50-ditana-xdg.conf" \
          "/etc/profile.d/ditana-xdg.sh" \
          \ // === Ditana helper scripts ===
          "/usr/lib/ditana/first-login" \
          \ // === Pacseek launcher ===
          "/usr/share/applications/pacseek-desktop.desktop" \
          \ // === Logos ===
          "/usr/share/pixmaps/ditana-logo-small.png" \
          "/usr/share/pixmaps/ditana-shakehands.png" \
          \ // === Enable files in /etc/dconf/db/local.d/ ===
          "/etc/dconf/profile/user"
    chroot-script "systemctl enable greetd.service" \
                  "usermod -aG video,input greeter" \
                  "fc-cache -fv" \
                  "sudo mkdir -p /var/cache/tuigreet" \
                  "sudo chmod 755 /var/cache/tuigreet" \
                  "sudo chown greeter:greeter /var/cache/tuigreet" \
                  #"printf "%s" "$USER_NAME" > /var/cache/tuigreet/lastuser"# \
                  "sudo chmod 640 /var/cache/tuigreet/lastuser" \
                  "sudo chown greeter:greeter /var/cache/tuigreet/lastuser"
    autostart {
        - "" "/usr/lib/ditana/first-login"
    }
  }
  
- name="fonts" \
  default-value="`install-desktop-environment`" {
      files "/etc/fonts/local.conf"
      arch-packages \
          "adobe-source-serif-fonts" \
          "otf-comicshanns-nerd" \
          "otf-font-awesome" \
          "terminus-font" \
          "ttf-jetbrains-mono-nerd" \
          "noto-fonts" \
          "noto-fonts-cjk" \
          "noto-fonts-extra" \
          "noto-fonts-emoji" \
          "ttf-twemoji"
  }

- name="xkb-environment" \
  default-value="`install-desktop-environment`" {
    files "/etc/environment.d/50-ditana-xkb.conf"
    chroot-script \
        #"sed -i 's|@@KEYMAP_LAYOUT@@|'"$KEYMAP_LAYOUT"'|' /etc/environment.d/50-ditana-xkb.conf"# \
        #"if [[ -n "$KEYMAP_VARIANT" ]]; then"# \
        #"    sed -i 's|@@KEYMAP_VARIANT@@|'"$KEYMAP_VARIANT"'|' /etc/environment.d/50-ditana-xkb.conf"# \
        "else" \
        "    sed -i '/@@KEYMAP_VARIANT@@/d' /etc/environment.d/50-ditana-xkb.conf" \
        "fi"
  }

- name="install-thunar" default-value="`install-desktop-environment`" {
    arch-packages "thunar" \
                  "catfish" \
                  "gvfs" \
                  "thunar-archive-plugin" \
                  "thunar-media-tags-plugin" \
                  "thunar-volman" \
                  "tumbler" \
                  \ // === Tumbler thumbnailer plugin dependencies ===
                  "libgepub" \
                  "libopenraw" \
                  "libgsf"
    files \ // === Thunar custom actions ===
          "/etc/skel/.config/Thunar/uca.xml" \
          "/usr/lib/ditana/open-disk-manager" \
          "/usr/lib/ditana/copy-path-to-clipboard"
    mime-defaults {
        - "thunar.desktop" "inode/directory"
    }
  }

- name="install-ramdisk-thunar-bookmark" \
  default-value="`install-thunar AND install-ramdisk`" {
    files \ // Adds a "RAM Disk" entry to the Thunar sidebar on first login (tmpfiles.d writes the bookmarks file only if it doesn't exist yet)
          "/usr/share/user-tmpfiles.d/ditana-thunar-ramdisk.conf"
  }

- name="install-vlc" default-value="`install-desktop-environment`" {
    arch-packages "vlc"
    mime-defaults {
        - "vlc.desktop" \
          "audio/3gpp" "audio/3gpp2" "audio/aac" "audio/ac3" "audio/amr" "audio/amr-wb" "audio/basic" \
          "audio/dv" "audio/eac3" "audio/flac" "audio/m4a" "audio/midi" "audio/mp1" "audio/mp2" \
          "audio/mp3" "audio/mp4" "audio/mpeg" "audio/mpegurl" "audio/mpg" "audio/ogg" "audio/opus" \
          "audio/scpls" "audio/vnd.dolby.dd-raw" "audio/vnd.dts" "audio/vnd.dts.hd" "audio/vnd.rn-realaudio" \
          "audio/vorbis" "audio/wav" "audio/webm" "audio/x-aac" "audio/x-aiff" "audio/x-ape" "audio/x-flac" \
          "audio/x-m4a" "audio/x-matroska" "audio/x-mp1" "audio/x-mp2" "audio/x-mp3" "audio/x-mpeg" \
          "audio/x-mpegurl" "audio/x-ms-asf" "audio/x-ms-asx" "audio/x-ms-wax" "audio/x-ms-wma" \
          "audio/x-musepack" "audio/x-pn-aiff" "audio/x-pn-au" "audio/x-pn-realaudio" \
          "audio/x-pn-realaudio-plugin" "audio/x-pn-wav" "audio/x-pn-windows-acm" "audio/x-real-audio" \
          "audio/x-realaudio" "audio/x-shorten" "audio/x-speex" "audio/x-tta" "audio/x-vorbis" \
          "audio/x-vorbis+ogg" "audio/x-wav" "audio/x-wavpack" "audio/x-adpcm" "audio/x-gsm" "audio/x-it" \
          "audio/x-mod" "audio/x-s3m" "audio/x-xm" "audio/x-scpls" "audio/vnd.dolby.heaac.1" \
          "audio/vnd.dolby.heaac.2" "audio/vnd.dolby.mlp" \
          "video/3gp" "video/3gpp" "video/3gpp2" "video/avi" "video/dv" "video/fli" "video/flv" "video/mp2t" \
          "video/mp4" "video/mp4v-es" "video/mpeg" "video/mpeg-system" "video/msvideo" "video/ogg" \
          "video/quicktime" "video/vnd.mpegurl" "video/vnd.rn-realvideo" "video/webm" "video/x-avi" \
          "video/x-flc" "video/x-fli" "video/x-flv" "video/x-m4v" "video/x-matroska" "video/x-mpeg" \
          "video/x-mpeg-system" "video/x-mpeg2" "video/x-ms-asf" "video/x-ms-asf-plugin" "video/x-ms-asx" \
          "video/x-ms-wm" "video/x-ms-wmv" "video/x-ms-wmx" "video/x-ms-wvx" "video/x-msvideo" "video/x-ogm" \
          "video/x-ogm+ogg" "video/x-theora" "video/x-theora+ogg" "video/x-anim" "video/x-nsv" "video/divx" \
          "video/vnd.divx" \
          "application/ogg" "application/x-ogg" "application/mxf" "application/sdp" "application/vnd.ms-asf" \
          "application/vnd.ms-wpl" "application/vnd.rn-realmedia" "application/vnd.rn-realmedia-vbr" \
          "application/ram" "application/xspf+xml" "application/vnd.apple.mpegurl" "application/x-cd-image" \
          "application/x-extension-m4a" "application/x-extension-mp4" "application/x-matroska" \
          "application/x-quicktime-media-link" "application/x-quicktimeplayer" "application/x-shockwave-flash" \
          "application/x-flash-video" "application/mpeg4-iod" "application/mpeg4-muxcodetable" \
          "x-scheme-handler/mms" "x-scheme-handler/mmsh" "x-scheme-handler/rtsp" "x-scheme-handler/rtp" \
          "x-scheme-handler/rtmp" "x-scheme-handler/icy" "x-scheme-handler/icyx" "x-content/video-vcd" \
          "x-content/video-svcd" "x-content/video-dvd" "x-content/audio-cdda" "x-content/audio-player" \
          "text/google-video-pointer" "text/x-google-video-pointer" "image/vnd.rn-realpix" "misc/ultravox"
    }
  }

- name="install-ristretto" default-value="`install-desktop-environment`" {
    arch-packages "ristretto"
    mime-defaults {
        - "org.xfce.ristretto.desktop" \
          "image/bmp" "image/gif" "image/jpeg" "image/jpg" "image/pjpeg" "image/png" \
          "image/svg+xml" "image/svg+xml-compressed" "image/tiff" "image/vnd.microsoft.icon" \
          "image/x-bmp" "image/x-gray" "image/x-icb" "image/x-ico" "image/x-icon" "image/x-pcx" \
          "image/x-png" "image/x-portable-anymap" "image/x-portable-bitmap" "image/x-portable-graymap" \
          "image/x-portable-pixmap" "image/x-xbitmap" "image/x-xpixmap"
    }
  }

- name="install-xreader" default-value="`install-desktop-environment`" {
    arch-packages "xreader"
  }

- name="install-engrampa" default-value="`install-desktop-environment`" {
    arch-packages "engrampa"
    mime-defaults {
        - "engrampa.desktop" \
          "application/x-7z-compressed" "application/x-7z-compressed-tar" "application/x-ace" \
          "application/x-alz" "application/x-ar" "application/x-archive" "application/x-arj" \
          "application/x-bzip" "application/x-bzip-compressed-tar" "application/x-bzip1" \
          "application/x-bzip1-compressed-tar" "application/x-cabinet" "application/x-cd-image" \
          "application/x-compress" "application/x-compressed-tar" "application/x-cpio" \
          "application/x-deb" "application/x-gtar" "application/x-gzip" "application/x-gzpostscript" \
          "application/x-java-archive" "application/x-lha" "application/x-lhz" "application/x-lrzip" \
          "application/x-lrzip-compressed-tar" "application/x-lz4" "application/x-lz4-compressed-tar" \
          "application/x-lzip" "application/x-lzip-compressed-tar" "application/x-lzma" \
          "application/x-lzma-compressed-tar" "application/x-lzop" "application/x-lzop-compressed-tar" \
          "application/x-rar" "application/x-rar-compressed" "application/x-rpm" "application/x-rzip" \
          "application/x-rzip-compressed-tar" "application/x-tar" "application/x-tarz" "application/x-tzo" \
          "application/x-xar" "application/x-xz" "application/x-xz-compressed-tar" "application/x-zip" \
          "application/x-zip-compressed" "application/x-zstd-compressed-tar" "application/x-zoo" \
          "application/zip" "application/gzip" "application/bzip2"
    }
  }
