        "/usr/share/cosmic/com.system76.CosmicPanel.Panel/v1/border_radius" \
        "/usr/share/cosmic/com.system76.CosmicPanel.Panel/v1/exclusive_zone" \
        "/usr/share/cosmic/com.system76.CosmicPanel.Panel/v1/expand_to_edges" \
        "/usr/share/cosmic/com.system76.CosmicPanel.Panel/v1/keyboard_interactivity" \
        "/usr/share/cosmic/com.system76.CosmicPanel.Panel/v1/layer" \
        "/usr/share/cosmic/com.system76.CosmicPanel.Panel/v1/margin" \
        "/usr/share/cosmic/com.system76.CosmicPanel.Panel/v1/name" \
        "/usr/share/cosmic/com.system76.CosmicPanel.Panel/v1/opacity" \
        "/usr/share/cosmic/com.system76.CosmicPanel.Panel/v1/output" \
