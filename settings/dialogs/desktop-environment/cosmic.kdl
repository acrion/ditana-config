        "/usr/share/cosmic/com.system76.CosmicPanel.Panel/v1/anchor_gap" \
        "/usr/share/cosmic/com.system76.CosmicPanel.Panel/v1/autohide" \
        "/usr/share/cosmic/com.system76.CosmicPanel.Panel/v1/autohover_delay_ms" \
