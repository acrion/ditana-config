// === COSMIC AppList configuration ===
//
// The favorites list (the icons docked in the COSMIC panel) ships as
// a template with placeholders for the user-chosen browser, terminal
// and file manager. Each user choice has its own configure-cosmic-favorites-*
// component below; they substitute the placeholders via sed at chroot
// time. The radiolist semantics of the Browser, Terminal Emulator and
// File Manager dialogs guarantee mutual exclusivity, so exactly one
// substitution per placeholder fires. The "no-*" components delete the
// corresponding line entirely.

- name="install-cosmic-applist-config" \
  default-value="`install-cosmic`" {
    files "/usr/share/cosmic/com.system76.CosmicAppList/v1/enable_drag_source" \
          "/usr/share/cosmic/com.system76.CosmicAppList/v1/favorites" \
          "/usr/share/cosmic/com.system76.CosmicAppList/v1/filter_top_levels"
}

// --- Browser substitution ---
- name="configure-cosmic-favorites-firefox" \
  default-value="`install-cosmic AND install-firefox`" {
    chroot-script "sed -i 's|@@COSMIC_BROWSER_ID@@|firefox|' /usr/share/cosmic/com.system76.CosmicAppList/v1/favorites"
}

- name="configure-cosmic-favorites-librewolf" \
  default-value="`install-cosmic AND install-librewolf`" {
    chroot-script "sed -i 's|@@COSMIC_BROWSER_ID@@|io.gitlab.librewolf-community|' /usr/share/cosmic/com.system76.CosmicAppList/v1/favorites"
}

- name="configure-cosmic-favorites-brave" \
  default-value="`install-cosmic AND install-brave`" {
    chroot-script "sed -i 's|@@COSMIC_BROWSER_ID@@|brave|' /usr/share/cosmic/com.system76.CosmicAppList/v1/favorites"
}

- name="configure-cosmic-favorites-mullvad" \
  default-value="`install-cosmic AND install-mullvad`" {
    chroot-script "sed -i 's|@@COSMIC_BROWSER_ID@@|net.mullvad.MullvadBrowser|' /usr/share/cosmic/com.system76.CosmicAppList/v1/favorites"
}

- name="configure-cosmic-favorites-no-browser" \
  default-value="`install-cosmic AND install-no-browser`" {
    chroot-script "sed -i '/@@COSMIC_BROWSER_ID@@/d' /usr/share/cosmic/com.system76.CosmicAppList/v1/favorites"
}

// --- Terminal substitution ---
- name="configure-cosmic-favorites-cosmic-term" \
  default-value="`install-cosmic AND install-cosmic-term`" {
    chroot-script "sed -i 's|@@COSMIC_TERMINAL_ID@@|com.system76.CosmicTerm|' /usr/share/cosmic/com.system76.CosmicAppList/v1/favorites"
}

