- name="install-xfce" \
  dialog-name="Desktop Environment" \
  short-description="XFCE (Xorg)" \
  long-description="XFCE: A mature, lightweight desktop environment running on Xorg (X11). XFCE offers a traditional desktop paradigm with a panel, application menu, and window management. It is highly customizable, resource-efficient, and has broad hardware and software compatibility. Ditana ships a preconfigured XFCE setup with the Dracula theme, Kitty or Ghostty terminal, and curated panel plugins." \
  spdx-identifiers="GPL-2.0-or-later" \
  default-value="`NOT profile-server`" {
    arch-packages "xorg-server" \
                  "xorg-xinit" \
                  \ // === group xfce4 without xfce4-terminal ===
                  "exo" \
                  "garcon" \
                  "xfce4-appfinder" \
                  "xfce4-panel" \
                  "xfce4-power-manager" \
                  "xfce4-session" \
                  "xfce4-settings" \
                  "xfconf" \
                  "xfdesktop" \
                  "xfwm4" \
                  \ // === XFCE plugins ===
                  "xfce4-screenshooter" \
                  "xfce4-screensaver" \
                  "xfce4-notifyd" \
                  \ // === On-screen keyboard ===
                  "onboard" \
                  \ // === Color picker ===
                  "gpick" \
                  \ // === XFCE panel plugins ===
                  "xfce4-docklike-plugin" \
                  "xfce4-genmon-plugin" \
                  "xfce4-notes-plugin" \
                  "xfce4-weather-plugin" \
                  "xfce4-whiskermenu-plugin" \
                  "xfce4-xkb-plugin" \
                  "xfce4-pulseaudio-plugin" \
                  \ // === X11 utilities ===
                  "xclip" \
                  "xsel" \
                  "xorg-xev" \
                  "xorg-xkill" \
                  "xorg-xrandr" \
                  "xorg-xhost" \
                  "lxsession" \
                  \ // === XFCE fixes ===
                  "mugshot" \
                  \ // === XDG Desktop Portal ===
                  "xdg-desktop-portal-gtk" \
                  \ // === XFCE Ditana specific ===
                  "xfce-display-config-observer" \
                  "xfce-wallpaper-overlay" \
                  "kalu" \
                  "pciutils" \
                  \ // === Script dependencies ===
                  "xmlstarlet" \
                  "bc" \
                  "zenity"
    files \ // === XFCE configuration ===
          "/usr/lib/ditana/start-xfce4-greetd" \
          "/usr/share/ditana/xsessions/xfce-ditana.desktop" \
          "/etc/skel/.config/xfce4/helpers.rc" \
          "/etc/skel/.config/xfce4/panel/docklike-2.rc" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xsettings.xml" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/thunar.xml" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfwm4.xml" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-session.xml" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-terminal.xml" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/thunar-volman.xml" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-panel.xml" \
          "/usr/lib/ditana/print-system-load" \ // configured in xfce4-panel.xml
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-power-manager.xml" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/keyboards.xml" \
          "/etc/skel/.config/xfce4/wallpaper-overlay/ditana-help-1.txt" \
          "/etc/skel/.config/xfce4/wallpaper-overlay/ditana-help-2.txt" \
          "/etc/skel/.config/xfce4/wallpaper-overlay/ditana-help-3.txt" \
          "/etc/skel/.config/xfce4/wallpaper-overlay/ditana-help-4.txt" \
          \ // === Kalu config ===
          "/etc/skel/.config/kalu/kalu.conf" \
          \ // === Desktop shortcuts ===
          "/etc/skel/Desktop/Donate to Ditana.desktop" \
          "/etc/skel/Desktop/Best Practices.desktop" \
          \ // === Ditana XFCE helper scripts ===
          "/usr/lib/ditana/xfce-first-login" \
          \ // === Wallpapers ===
          "/usr/share/backgrounds/xfce/ditana-wallpaper.jpg" \
          "/usr/share/backgrounds/xfce/ditana-blue.png" \
          \ // === Qt Scaling ===
          "/etc/skel/.config/systemd/user-environment-generators/50-qt-hidpi-xfce-ditana"
    early-chroot-script \
      \ // Patch the xfconf keyboards.xml with the user-selected repeat values.
      #"sed -i 's|@@KEYBOARD_DELAY@@|'"$KEYBOARD_DELAY"'|' /etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/keyboards.xml"# \
      #"sed -i 's|@@KEYBOARD_RATE@@|'"$KEYBOARD_RATE"'|' /etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/keyboards.xml"#
    chroot-script "rm -f /usr/share/wayland-sessions/xfce-wayland.desktop" \ // remove XFCE (Wayland) entry
                  "sed -i '/^#*NoExtract/a NoExtract = usr/share/wayland-sessions/xfce-wayland.desktop' /etc/pacman.conf"
    autostart {
        - "XFCE;" "/usr/lib/ditana/xfce-first-login"
        - "XFCE;" "/usr/bin/kalu"
    }
  }

- name="install-xfce-thunar" default-value="`install-xfce AND install-thunar`" {
    first-login-commands #"sed -i "s|^FileManager=.*|FileManager=thunar|" "$HOME/.config/xfce4/helpers.rc""#
  }

