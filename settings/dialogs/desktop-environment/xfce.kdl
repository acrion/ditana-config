// === related to terminal-emulator.kdl ===

// XFCE fallback for the foot-Wayland-only case. This is a regular
// dependent setting that fires only when foot is the primary terminal
// and XFCE is also installed. Writes to xfce-xdg-terminals.list only;
// xdg-terminals.list still points at footclient for Wayland sessions.
- name="fallback-alacritty-for-xfce" \
  default-value="`install-foot AND install-xfce`" {
    arch-packages "alacritty"
    chroot-script "mkdir -p /etc/xdg" \
                  "echo Alacritty.desktop >/etc/xdg/xfce-xdg-terminals.list"
  }

- name="install-xfce-alacritty" default-value="`fallback-alacritty-for-xfce OR (install-xfce AND install-alacritty)`" {
    first-login-commands \
        #"if command -v alacritty &> /dev/null; then"# \
        #"    sed -i "/^pinned=/ s/pinned=/pinned=Alacritty;/" "$HOME/.config/xfce4/panel/docklike-2.rc""# \
        #"    sed -i "s|^TerminalEmulator=.*|TerminalEmulator=alacritty|" "$HOME/.config/xfce4/helpers.rc""# \
        #"fi"#
  }

