// Settings that correspond to the dialog "Configuration Categories" → "Browser"
// Browser radiolist. The «None» entry is the auto-selected default for
// headless / server installs without a desktop environment.

- name="install-librewolf" \
  dialog-name="Browser" \
  short-description="LibreWolf - Privacy-hardened Firefox fork" \
  long-description="LibreWolf is a community-maintained fork of Firefox that ships with stronger default privacy and security settings out of the box (no telemetry, stricter cookie / referrer policy, hardened TLS settings). Distributed as a Flatpak; the download is one of the longest network steps in a default Ditana install." \
  spdx-identifiers="MPL-2.0" \
  available="`install-desktop-environment`" \
  default-value="`install-desktop-environment AND NOT (profile-quick OR profile-windows)`" {
    files "/etc/skel/.librewolf/librewolf.overrides.cfg"
    flatpak-packages "io.gitlab.librewolf-community"
}

- name="install-firefox" \
  dialog-name="Browser" \
  short-description="Firefox - Mozilla's standard browser" \
  long-description="Firefox from the Arch repository. Significantly faster to install than the Flatpak browsers because it does not require fetching a Flatpak runtime. Includes onnxruntime (smart-tab-group ML features) and speech-dispatcher (text-to-speech) as recommended optional dependencies." \
  spdx-identifiers="MPL-2.0" \
  available="`install-desktop-environment`" \
  default-value="`install-desktop-environment AND profile-quick`" {
    arch-packages "firefox" \
                  "onnxruntime" \
                  "speech-dispatcher"
}

- name="install-brave" \
  dialog-name="Browser" \
  short-description="Brave - Chromium-based with built-in ad/tracker blocking" \
  long-description="Brave is a Chromium-based browser with built-in ad and tracker blocking, fingerprinting protections and an optional native tip / rewards system. Useful when site compatibility requires a Blink engine but Chrome itself is not desired." \
  spdx-identifiers="MPL-2.0" \
  available="`install-desktop-environment`" \
  default-value="`install-desktop-environment AND profile-windows`" {
    \ // We do not use the Flatpak com.brave.Browser because it would require kernel.unprivileged_userns_clone=1
    \ // for its inner zypak/Chromium sandbox (increasing the kernel attack surface). Installation of bubblewrap-suid
    \ // does not help. Instead we use the native AUR package brave-bin, which works flawlessly with userns=0
    \ // via its own chrome-sandbox helper. See https://wiki.archlinux.org/title/Security#Sandboxing_applications
    aur-packages "brave-bin"
  }

- name="fix-brave-for-cosmic" \
  default-value="`install-brave AND install-cosmic`" {
      files "/usr/local/bin/brave"
  }

- name="install-mullvad-browser" \
  dialog-name="Browser" \
  short-description="Mullvad Browser - Anti-fingerprinting Tor-style hardening" \
  long-description="A privacy-focused browser developed by Mullvad VPN in collaboration with the Tor Project, applying many of Tor Browser's anti-fingerprinting and tracking-resistance techniques without routing traffic through Tor itself." \
  spdx-identifiers="MPL-2.0" \
  available="`install-desktop-environment`" \
  default-value=#false {
    flatpak-packages "net.mullvad.MullvadBrowser"
}

- name="install-no-browser" \
  dialog-name="Browser" \
  short-description="None - Do not install a browser" \
  long-description="Skip browser installation. Auto-selected for headless / server installs. You can install one later via pacman or Flatpak." \
  spdx-identifiers="" \
  default-value="`NOT install-desktop-environment`" {
    arch-packages ""
}
