// Settings that correspond to the dialog "Configuration Categories" -> "Advanced Settings" → "sudo-timeout"
- name="sudo-timeout" \
  category="system" \
  dialog-name="Advanced Settings" \
  short-description="Sudo password timeout (minutes)" \
  long-description="Configure how many minutes sudo remembers the password before prompting again. Creates a sudoers override file in /etc/sudoers.d/ with correct permissions." \
  spdx-identifiers="ISC" \
  default-value=5 {
    chroot-script "`echo 'Defaults timestamp_timeout={Settings.instance.get('sudo-timeout')}' > /etc/sudoers.d/99-timeout`" \
                  "chmod 440 /etc/sudoers.d/99-timeout" \
                  "chown root:root /etc/sudoers.d/99-timeout"
  }
