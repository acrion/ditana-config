// Settings that correspond to the dialog "Configuration Categories" -> "Advanced Settings" → "Kernel Selection"
//
// Ditana offers only kernels from the official Arch repositories. AUR kernels
// (such as linux-hardened-lts) are excluded because they depend on multiple
// independent upstream maintainers (kernel.org stable team, patch authors,
// AUR packagers) whose release schedules are uncoordinated. A single delayed
// fix — such as a GCC major version incompatibility in a plugin header — can
// block the entire Ditana build pipeline with no recourse.
//
// The default is linux-lts: it provides the best balance of stability and DKMS
// module compatibility (ZFS, NVIDIA). Non-LTS kernels are offered as expert
// options. Users selecting them should be aware that DKMS modules may
// temporarily fail to build after kernel updates until the module maintainers
// catch up.
- name="install-standard-stable-kernel" \
  dialog-name="Kernel Selection" \
  short-description="Standard Kernel (Stable)" \
  long-description="Standard Kernel (linux) [Stable]: The standard kernel offers balanced performance and broad hardware support. As a non-LTS release, it receives frequent updates that may temporarily break DKMS modules (e.g., ZFS, NVIDIA). Recommended only if you need drivers or features not yet available in the LTS kernel." \
  spdx-identifiers="GPL-2.0-only" \
  default-value="`b43-required`" {
    arch-packages "linux" "linux-headers"
  }
- name="install-standard-lts-kernel" \
  dialog-name="Kernel Selection" \
  short-description="Standard Kernel (LTS)" \
  long-description="Standard Kernel (linux-lts) [LTS]: The Long-Term Support kernel provides extended maintenance and maximum compatibility with DKMS modules such as ZFS and NVIDIA drivers. Recommended for most users." \
  spdx-identifiers="GPL-2.0-only" \
  available="`NOT b43-required`" \
  default-value="`NOT b43-required`" {
    arch-packages "linux-lts" \
                  "linux-lts-headers"
  }
- name="install-hardened-stable-kernel" \
  dialog-name="Kernel Selection" \
  short-description="Hardened Kernel (Stable)" \
  long-description="Hardened Kernel (linux-hardened) [Stable]: Applies security-focused patches and compile-time hardening options for enhanced exploit protection. As a non-LTS release, DKMS modules may temporarily break after updates. Note: linux-hardened disables unprivileged user namespaces by default, which is why the separate «Disable unprivileged user namespaces» option is shown as unavailable when this kernel is selected — see that option for the trade-off discussion (browser sandboxing, rootless containers, wrapper-based sandboxing)." \
  spdx-identifiers="GPL-2.0-only" \
  available="`NOT b43-required`" \
  default-value=#false {
    arch-packages "linux-hardened" \
                  "linux-hardened-headers"
  }
- name="install-zen-kernel" \
  dialog-name="Kernel Selection" \
  short-description="Zen Kernel (Stable)" \
  long-description="Zen Kernel (linux-zen) [Stable]: Tuned for desktop responsiveness with an optimized CPU scheduler and relaxed preemption settings. As a non-LTS release, DKMS modules may temporarily break after updates. Usually works well with the NVIDIA DKMS driver but may not be ideal for systems relying on «zfs-dkms»." \
  spdx-identifiers="GPL-2.0-only" \
  available="`NOT b43-required`" \
  default-value=#false {
    arch-packages "linux-zen" \
                  "linux-zen-headers"
  }
- name="install-realtime-lts-kernel" \
  dialog-name="Kernel Selection" \
  short-description="Realtime Kernel (LTS)" \
  long-description="Realtime Kernel (linux-rt-lts) [LTS]: Applies the PREEMPT_RT patch for deterministic response times. Ideal for audio/video production, live performance, and industrial control systems. As an LTS release, it offers the same DKMS stability as the standard LTS kernel." \
  spdx-identifiers="various, incl GPL-1.0-or-later,BSD-3-Clause-Clear" \
  available="`NOT b43-required`" \
  default-value=#false {
    arch-packages "linux-rt-lts" \
                  "linux-rt-lts-headers"
  }
