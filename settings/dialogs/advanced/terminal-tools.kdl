// Settings that correspond to the dialog "Configuration Categories" -> "Advanced Settings" → "Terminal Tools and Utilities"
- name="install-zsh" \
  dialog-name="Terminal Tools and Utilities" \
  short-description="Install zsh and make it default" \
  long-description="Install zsh and make it default: zsh enhances the command-line interface with features like improved tab completion, globbing, and programmable command-line completion. This will also install useful zsh plugins like syntax highlighting." \
  spdx-identifiers="zsh" \
  default-value=#true {
    arch-packages "zsh" \
                  "zsh-syntax-highlighting" \
                  "zsh-autosuggestions" \
                  "zsh-history-substring-search" \
                  "fzf" \
                  "pkgfile"
    chroot-script #"useradd -D -s "$(which zsh)""# \
                  #"`chsh -s "\$(which zsh)" {Settings.instance.get('user-name')}`"#
    files "/etc/skel/.zshrc"
  }
- name="install-cron" \
  dialog-name="Terminal Tools and Utilities" \
  short-description="Install cron and activate service" \
  long-description="Install cron and activate service: cron is a common service that allows for the scheduling of regular jobs directly from the terminal." \
  spdx-identifiers="" \
  default-value="`install-backintime`" {
    arch-packages "cronie"
    chroot-script "systemctl enable cronie"
  }
- name="install-git" \
  default-value="`install-terminal-utilities" {
    arch-packages "git-lfs"
  }
- name="install-terminal-utilities" \
  dialog-name="Terminal Tools and Utilities" \
  short-description="Install essential terminal utilities like grep, rsync, bc..." \
  long-description="Install terminal utilities to enhance productivity: $packages. bat will be configured to act like cat, but with syntax highlighting." \
  spdx-identifiers="" \
  default-value=#true {
    arch-packages "bat" \
    "bc" \
    "bind" \
    "ditana-print-system-infos" \
    "expect" \ // for unbuffer
    "eza" \
    "fd" \
    "ffmpeg" \
    "fzf" \
    "git-lfs" \
    "jq" \
    "fakeroot" \
    "foot-terminfo" \
    "ghostty-terminfo" \
    "grep" \
    "htop" \
    "img2pdf" \
    "inotify-tools" \
    "kitty-terminfo" \
    "less" \
    "lsof" \
    "lua" \
    "man-db" \
    "mediainfo" \
    "ncdu" \
    "neovim" \
    "perl-image-exiftool" \
    "rsync" \
    "sed" \
    "starship" \ // used by bash and zsh configuration (if installed)
    "systemctl-tui" \
    "trash-cli" \
    "turbostat" \
    "zoxide" \
    "zellij"
    files "/etc/skel/.config/bat/config"
    chroot-script "`su - {Settings.instance.get('user-name')} -c 'git lfs install'`"
  }
- name="install-ripgrep" \
  default-value="`install-terminal-utilities`" {
    arch-packages "ripgrep"
    files "/etc/skel/.config/ripgrep/ripgreprc"
  }
  
- name="install-fresh" \
  dialog-name="Terminal Tools and Utilities" \
  short-description="Install fresh editor and set it as default" \
  long-description="""
Install fresh editor and set it as default: fresh is a lightweight, fast terminal-based text editor with LSP support, mirroring the user interface of GUI editors.
""" \
  spdx-identifiers="GPL-2.0-only" \
  default-value=#true {
    files "/etc/skel/.config/fresh/config.json" \
          \ // Override the upstream fresh.desktop to use Ditana's standard
          \ // xdg-terminal-exec mechanism. The upstream file uses Terminal=true,
          \ // which delegates terminal selection to the file manager's handler
          \ // (exo-helper under Thunar). Calling xdg-terminal-exec directly is
          \ // simpler and DE-agnostic.
          "/etc/skel/.local/share/applications/fresh.desktop"
    chroot-script "mkdir -p /etc/profile.d" \
                  "mkdir -p /etc/environment.d" \
                  "cat <<'DITANA_ENV' >> /etc/profile.d/ditana-set-default-editor.sh" \
                  "export EDITOR=/usr/lib/ditana-fresh-edit" \
                  "export VISUAL=/usr/lib/ditana-fresh-edit" \
                  "DITANA_ENV" \
                  "cat <<'DITANA_ENV' >> /etc/environment.d/90-ditana-default-editor.conf" \
                  "EDITOR=/usr/lib/ditana-fresh-edit" \
                  "VISUAL=/usr/lib/ditana/fresh-edit" \
                  "DITANA_ENV"
    arch-packages "fresh-editor-bin"
  }
- name="install-yazi" \
  dialog-name="Terminal Tools and Utilities" \
  short-description="Install yazi terminal file manager including optional packages" \
  long-description="Install yazi, a blazing fast terminal file manager written in Rust, including optional packages for thumbnails, previews, searching, and clipboard support." \
  spdx-identifiers="MIT" \
  default-value=#true {
    arch-packages "yazi" \
                  "chafa" \ // fallback ASCII image preview
                  "imagemagick" \ // for image and font preview
                  "poppler" \ // for PDF preview
                  "resvg" // for SVG preview
  }
- name="install-archivers" \
  dialog-name="Terminal Tools and Utilities" \
  short-description="Install various command line archivers like zip, unzip, 7z..." \
  long-description="Install various command line archivers: $packages." \
  spdx-identifiers="" \
  default-value=#true {
    arch-packages "7zip" \
                  "arj" \
                  "bzip2" \
                  "cpio" \
                  "gzip" \
                  "lhasa" \
                  "lrzip" \
                  "lz4" \
                  "lzip" \
                  "lzop" \
                  "tar" \
                  "unarj" \
                  "unrar" \
                  "unzip" \
                  "xz" \
                  "zip" \
                  "zstd"
  }
