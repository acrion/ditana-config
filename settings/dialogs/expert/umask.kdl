// Settings that correspond to the dialog "Configuration Categories" -> "Expert Settings" → "Umask Configuration"
- name="umask-027" \
  dialog-name="Umask Configuration" \
  short-description="Restrictive (027) — Ditana Default" \
  long-description="Restrictive Umask (027): New files are created with permissions 640 (owner: read/write, group: read, others: none) and new directories with 750 (owner: full, group: read/execute, others: none). This prevents other users on the system from accessing your files while still allowing group members to read them. Recommended for most users." \
  spdx-identifiers="" \
  required-by-chroot=#true \
  default-value=#true

- name="umask-077" \
  dialog-name="Umask Configuration" \
  short-description="Private (077)" \
  long-description="Private Umask (077): New files are created with permissions 600 (owner: read/write only) and new directories with 700 (owner: full access only). No other user, including group members, can access newly created files. This provides maximum privacy but may cause issues with services or applications that expect group-readable files." \
  spdx-identifiers="" \
  required-by-chroot=#true default-value=#false

- name="umask-022" \
  dialog-name="Umask Configuration" \
  short-description="Permissive (022) — Linux Default" \
  long-description="Permissive Umask (022): New files are created with permissions 644 (owner: read/write, others: read) and new directories with 755 (owner: full, others: read/execute). This is the standard Linux default and allows all users on the system to read your files. Choose this if you rely on software that expects world-readable files or if you are the only user on the system." \
  spdx-identifiers="" \
  default-value=#false
