// Office Suite radiolist. The previous install-libreoffice block in
// desktop-applications.kdl moves here verbatim (chroot-script unchanged)
// and gains profile-aware defaults; ONLYOFFICE and «None» are added.

- name="install-libreoffice" \
  dialog-name="Office Suite" \
  short-description="LibreOffice - Comprehensive open-source office suite" \
  long-description="LibreOffice is a powerful open-source office suite that includes applications for word processing, spreadsheets, presentations, vector graphics, databases, and more. With comprehensive file format compatibility and robust support for extensions, it is a versatile alternative to proprietary office software. The appropriate language pack for your system will be installed (falling back to English if no localized package is available)." \
  spdx-identifiers="LGPL-3.0-or-later" \
  available="`install-desktop-environment`" \
  default-value="`install-desktop-environment AND NOT (profile-windows OR profile-quick)`" {
    arch-packages ""
    chroot-script "`MAIN_LOCALE={Settings.instance.get('main-locale')}`" \
                  #"LIBREOFFICE="libreoffice-still-$MAIN_LOCALE""# \
                  #"if ! is_package_available "$LIBREOFFICE"; then"# \
                  #"    if [ "$MAIN_LOCALE" != "en" ]; then"# \
                  #"        echo -e "\033[33m--- Unable to localize Libre Office for $MAIN_LOCALE ---\033[0m""# \
                  "    fi" \
                  #"    LIBREOFFICE="libreoffice-still""# \
                  "fi" \
                  #"echo -e "\033[32m--- Installing $LIBREOFFICE ---\033[0m""# \
                  #"runuser -u builduser -- pikaur -S "$LIBREOFFICE" --noconfirm || true"#
}

- name="install-onlyoffice" \
  dialog-name="Office Suite" \
  short-description="ONLYOFFICE - MS-Office-style ribbon UI" \
  long-description="ONLYOFFICE Desktop Editors offers a ribbon-style interface familiar to Microsoft Office users, with strong .docx / .xlsx / .pptx compatibility for documents, spreadsheets and presentations. Distributed as a Flatpak (~1.3 GB)." \
  spdx-identifiers="AGPL-3.0-only" \
  available="`install-desktop-environment`" \
  default-value="`install-desktop-environment AND (profile-windows OR profile-quick)`" {
    flatpak-packages "org.onlyoffice.desktopeditors"
}

- name="install-no-office" \
  dialog-name="Office Suite" \
  short-description="None - Do not install an office suite" \
  long-description="Skip office suite installation. Auto-selected for headless / server installs." \
  spdx-identifiers="" \
  default-value="`NOT install-desktop-environment`" {
    arch-packages ""
}
