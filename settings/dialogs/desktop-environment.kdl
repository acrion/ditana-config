// Settings that correspond to the dialog "Configuration Categories" → "Desktop Environment"
- name="install-desktop-environment" default-value="`install-xfce OR install-wayfire OR install-niri`" {
    arch-packages \ // === Fonts ===
                  "adobe-source-serif-fonts" \
                  "otf-comicshanns-nerd" \
                  "otf-font-awesome" \
                  "terminus-font" \
                  "ttf-jetbrains-mono-nerd" \
                  "noto-fonts" \
                  "noto-fonts-cjk" \
                  "noto-fonts-extra" \
                  "noto-fonts-emoji" \
                  "ttf-twemoji" \
                  \ // === Theming ===
                  "dracula-gtk-theme" \
                  "kora-yellow-icon-theme" \
                  \ // === greetd ===
                  "greetd" \
                  "greetd-tuigreet" \
                  "uwsm" \
                  \ // === XDG utilities ===
                  "xdg-user-dirs" \
                  "xdg-utils" \
                  \ // === Key management ===
                  "seahorse" \
                  \ // === Bluetooth (GUI) ===
                  "blueman" \
                  \ // === Audio ===
                  "pavucontrol" \
                  \ // === Network tray ===
                  "network-manager-applet" \
                  \ // === Security updates indicator ===
                  "arch-audit-gtk" \
                  \ // === GPU diagnostics ===
                  "mesa-utils" \
                  "libva-utils" \
                  "intel-gpu-tools" \
                  \ // === Color picker ===
                  "gpick" \
                  \ // === System resources monitor ===
                  "resources" \
                  \ // === Disk management ===
                  "gnome-disk-utility" \
                  \ // === Printing ===
                  "system-config-printer" \
                  "cups-pk-helper" \
                  "python-pysmbc" \
                  \ // === On-screen keyboard ===
                  "onboard"
    files \ // Marker file for first-login detection. If this file exists when the user logs in,
          \ // session-setup scripts marked with once=true (see "session-setup" below) are executed,
          \ // and the file is then deleted. See generate-session-setup() in Chroot.rakumod.
          "/etc/skel/.config/ditana/trigger-first-login" \
          \ // === Greetd configuration ===
          "/etc/greetd/config.toml" \
          \ // XDG user dirs. The upstream /etc/xdg/autostart/xdg-user-dirs.desktop
          \ // sets X-systemd-skip=true and X-GNOME-Autostart-Phase=EarlyInitialization;
          \ // both keys cause systemd-xdg-autostart-generator to skip the entry (see
          \ // systemd-xdg-autostart-generator(8) and upstream issue systemd/systemd#18791).
          \ // As a result the upstream entry does not run on compositors that rely on
          \ // systemd for XDG autostart (Niri, Wayfire via graphical-session.target).
          \ // XFCE4 has its own autostart handler that ignores those keys, so the
          \ // upstream entry works there. We ship an additional entry without the skip
          \ // keys so xdg-user-dirs-update runs on every DE; it is idempotent, so
          \ // running twice on XFCE is harmless.
          "/etc/xdg/autostart/ditana-xdg-user-dirs.desktop" \
          \ // XDG Base Directory Specification defaults, set explicitly for visibility
          \ // and robustness against spec-nonconforming apps. environment.d covers
          \ // systemd user services and logind-started sessions; the matching
          \ // /etc/profile.d/ditana-xdg.sh below covers interactive login shells.
          "/etc/environment.d/50-ditana-xdg.conf" \
          "/etc/profile.d/ditana-xdg.sh" \
          \ // === Fontconfig ===
          "/etc/skel/.config/fontconfig/fonts.conf" \
          \ // === GTK customization ===
          "/etc/skel/.config/gtk-3.0/gtk.css" \
          \ // === Ditana helper scripts ===
          "/usr/lib/ditana/open-disk-manager" \
          "/usr/lib/ditana/copy-path-to-clipboard" \
          "/usr/lib/ditana/first-login" \
          \ // === Pacseek launcher ===
          "/usr/share/applications/pacseek-desktop.desktop" \
          \ // === Logos ===
          "/usr/share/pixmaps/ditana-logo-small.png" \
          "/usr/share/pixmaps/ditana-shakehands.png" \
          \ // === Wayfire XDG autostart service ===
          "/usr/lib/systemd/user/ditana-wayfire-xdg-autostart.service"
    chroot-script "systemctl enable greetd.service" \
                  "usermod -aG video,input greeter" \
                  "fc-cache -fv" \
                  "cat <<'DITANA_ENV' >> /etc/environment" \
                  "# Fallback for apps not picking up the theme via gsettings" \
                  "GTK_THEME=Dracula" \
                  "DITANA_ENV"
    autostart {
        - "" "/usr/lib/ditana/first-login"
    }
  }
- name="xkb-environment" \
  default-value="`install-desktop-environment`" {
    files "/etc/environment.d/50-ditana-xkb.conf"
    chroot-script \
        "sed -i 's|@@KEYMAP_LAYOUT@@|'$KEYMAP_LAYOUT'|' /etc/environment.d/50-ditana-xkb.conf" \
        #"if [ -n "$KEYMAP_VARIANT" ]; then"# \
        "    sed -i 's|@@KEYMAP_VARIANT@@|'$KEYMAP_VARIANT'|' /etc/environment.d/50-ditana-xkb.conf" \
        "else" \
        "    sed -i '/@@KEYMAP_VARIANT@@/d' /etc/environment.d/50-ditana-xkb.conf" \
        "fi"
  }
- name="install-thunar" default-value="`install-desktop-environment`" {
    arch-packages "thunar" \
                  "catfish" \
                  "gvfs" \
                  "thunar-archive-plugin" \
                  "thunar-media-tags-plugin" \
                  "thunar-volman" \
                  "tumbler" \
                  \ // === Tumbler thumbnailer plugin dependencies ===
                  "libgepub" \
                  "libopenraw" \
                  "libgsf"
    files \ // === Thunar custom actions ===
          "/etc/skel/.config/Thunar/uca.xml"
  }
- name="install-ramdisk-thunar-bookmark" \
  default-value="`install-thunar AND install-ramdisk`" {
    files \ // Adds a "RAM Disk" entry to the Thunar sidebar on first login (tmpfiles.d writes the bookmarks file only if it doesn't exist yet)
          "/usr/share/user-tmpfiles.d/ditana-thunar-ramdisk.conf"
  }
- name="install-vlc" default-value="`install-desktop-environment`" {
    arch-packages "vlc"
  }
- name="install-ristretto" default-value="`install-desktop-environment`" {
    arch-packages "ristretto"
  }
- name="install-xreader" default-value="`install-desktop-environment`" {
    arch-packages "xreader"
  }
- name="install-librewolf" default-value="`install-desktop-environment`" {
    arch-packages "librewolf" \
                  "speech-dispatcher"
    files \ // === LibreWolf config ===
          "/etc/skel/.librewolf/librewolf.overrides.cfg"
    chroot-script "if [ -f /usr/lib/librewolf/distribution/policies.json ]; then" \
                  #"    sed -i 's/"Default": *"[^"]*"/"Default": "StartPage"/g' /usr/lib/librewolf/distribution/policies.json"# \
                  #"    sed -i '/"Remove": \[/,/\]/{ /"Google",/d }' /usr/lib/librewolf/distribution/policies.json"# \
                  "fi"
  }
- name="install-engrampa" default-value="`install-desktop-environment`" {
    arch-packages "engrampa"
  }
- name="install-xfce" \
  dialog-name="Desktop Environment" \
  short-description="XFCE (Xorg)" \
  long-description="XFCE: A mature, lightweight desktop environment running on Xorg (X11). XFCE offers a traditional desktop paradigm with a panel, application menu, and window management. It is highly customizable, resource-efficient, and has broad hardware and software compatibility. Ditana ships a preconfigured XFCE setup with the Dracula theme, Kitty or Ghostty terminal, and curated panel plugins." \
  spdx-identifiers="GPL-2.0-or-later" \
  default-value=#false {
    arch-packages "xorg-server" \
                  "xorg-xinit" \
                  \ // === group xfce4 without xfce4-terminal ===
                  "exo" \
                  "garcon" \
                  "xfce4-appfinder" \
                  "xfce4-panel" \
                  "xfce4-power-manager" \
                  "xfce4-session" \
                  "xfce4-settings" \
                  "xfconf" \
                  "xfdesktop" \
                  "xfwm4" \
                  \ // === XFCE plugins ===
                  "xfce4-screenshooter" \
                  "xfce4-screensaver" \
                  "xfce4-notifyd" \
                  \ // === XFCE panel plugins ===
                  "xfce4-docklike-plugin" \
                  "xfce4-genmon-plugin" \
                  "xfce4-notes-plugin" \
                  "xfce4-weather-plugin" \
                  "xfce4-whiskermenu-plugin" \
                  "xfce4-xkb-plugin" \
                  "xfce4-pulseaudio-plugin" \
                  \ // === X11 utilities ===
                  "xclip" \
                  "xsel" \
                  "xorg-xev" \
                  "xorg-xkill" \
                  "xorg-xrandr" \
                  "xorg-xhost" \
                  "lxsession" \
                  \ // === XFCE fixes ===
                  "mugshot" \
                  "gnome-keyring" \
                  \ // === XDG Desktop Portal ===
                  "xdg-desktop-portal-gtk" \
                  \ // === XFCE Ditana specific ===
                  "xfce-display-config-observer" \
                  "xfce-wallpaper-overlay" \
                  "kalu" \
                  "pciutils" \
                  \ // === Script dependencies ===
                  "xmlstarlet" \
                  "bc" \
                  "zenity"
    files \ // === XFCE configuration ===
          "/usr/lib/ditana/start-xfce4-greetd" \
          "/usr/share/ditana/xsessions/xfce-ditana.desktop" \
          "/etc/skel/.config/xfce4/helpers.rc" \
          "/etc/skel/.config/xfce4/panel/docklike-2.rc" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xsettings.xml" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/thunar.xml" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfwm4.xml" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-session.xml" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-terminal.xml" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/thunar-volman.xml" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-panel.xml" \
          "/usr/lib/ditana/print-system-load" \ // configured in xfce4-panel.xml
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-power-manager.xml" \
          "/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/keyboards.xml" \
          "/etc/skel/.config/xfce4/wallpaper-overlay/ditana-help-1.txt" \
          "/etc/skel/.config/xfce4/wallpaper-overlay/ditana-help-2.txt" \
          "/etc/skel/.config/xfce4/wallpaper-overlay/ditana-help-3.txt" \
          "/etc/skel/.config/xfce4/wallpaper-overlay/ditana-help-4.txt" \
          \ // === Kalu config ===
          "/etc/skel/.config/kalu/kalu.conf" \
          \ // === Desktop shortcuts ===
          "/etc/skel/Desktop/Donate to Ditana.desktop" \
          "/etc/skel/Desktop/Best Practices.desktop" \
          \ // === LibreWolf XFCE helper ===
          "/etc/skel/.local/share/xfce4/helpers/librewolf.desktop" \
          \ // === Ditana XFCE helper scripts ===
          "/usr/lib/ditana/pre-xfce-first-login" \
          "/usr/lib/ditana/xfce-first-login" \
          \ // === Wallpapers ===
          "/usr/share/backgrounds/xfce/ditana-wallpaper.jpg" \
          "/usr/share/backgrounds/xfce/ditana-blue.png"
    early-chroot-script \
      \ // Patch the xfconf keyboards.xml with the user-selected repeat values.
      "sed -i 's|@@KEYBOARD_DELAY@@|'$KEYBOARD_DELAY'|' /etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/keyboards.xml" \
      "sed -i 's|@@KEYBOARD_RATE@@|'$KEYBOARD_RATE'|' /etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/keyboards.xml"
    chroot-script "cat <<'DITANA_ENV' >> /etc/environment" \
                  "# https://wiki.archlinux.org/title/HiDPI#Qt_5" \
                  "# https://doc.qt.io/qt-5/highdpi.html" \
                  "QT_AUTO_SCREEN_SCALE_FACTOR=1" \
                  "QT_ENABLE_HIGHDPI_SCALING=1" \
                  "DITANA_ENV" \
                  "rm -f /usr/share/wayland-sessions/xfce-wayland.desktop" \ // remove XFCE (Wayland) entry from lightdm
                  "sed -i '/^#*NoExtract/a NoExtract = usr/share/wayland-sessions/xfce-wayland.desktop' /etc/pacman.conf"
    first-login-scripts "/usr/lib/ditana/pre-xfce-first-login"
    autostart {
        - "XFCE;" "/usr/lib/ditana/xfce-first-login"
        - "XFCE;" "/usr/bin/kalu"
    }
  }
- name="install-wayfire" \
  dialog-name="Desktop Environment" \
  short-description="Wayfire (Wayland)" \
  long-description="Wayfire: A modular Wayland compositor inspired by Compiz. Wayfire provides a stacking/floating window management experience on the modern Wayland display protocol, offering smooth animations, 3D effects, and a plugin-based architecture. It is a good choice for users who want a visually rich desktop without the legacy constraints of Xorg." \
  spdx-identifiers="MIT" \
  default-value=#true {
    files "/usr/lib/ditana/start-wayfire-greetd" \
          "/usr/share/ditana/wayland-sessions/wayfire-ditana.desktop" \
          \ // === Wayfire config ===
          "/etc/skel/.config/wayfire.ini" \
          "/usr/share/slick-greeter/badges/wayfire.svg"
    arch-packages "wayfire" \
                  "wayfire-plugins-extra" \
                  "wf-msg-git" \
                  "wlr-protocols" \
                  "wlr-randr" \
                  "wdisplays-persistent" \ // depends on kanshi
                  "wcm" \
                  "wf-config" \
                  "xdg-desktop-portal-wlr" \
                  "xorg-xwayland" \
                  "grim"
    \ // Wayfire does not reliably honor XKB_DEFAULT_LAYOUT/VARIANT from
    \ // /etc/environment.d/ — see upstream issues such as
    \ // https://github.com/WayfireWM/wayfire/issues/2178. We
    \ // therefore patch the [input] section of wayfire.ini.
    early-chroot-script \
        #"sed -i "s|^xkb_layout[[:space:]]*=.*|xkb_layout = ${KEYMAP_LAYOUT}|" /etc/skel/.config/wayfire.ini"# \
        #"if [ -n "${KEYMAP_VARIANT}" ]; then"# \
        #"    sed -i "s|^xkb_variant[[:space:]]*=.*|xkb_variant = ${KEYMAP_VARIANT}|" /etc/skel/.config/wayfire.ini"# \
        "fi"
    login-commands "if systemd-detect-virt -q; then" \
                   "    export WLR_NO_HARDWARE_CURSORS=1" \ // prevent upside down cursor in Wayfire
                   "fi"
    autostart {
        - "Wayfire;wayfire;" "/usr/bin/kanshi"
        - "Wayfire;wayfire;" "/usr/bin/waybar"
    }
  }
- name="install-niri" \
  dialog-name="Desktop Environment" \
  short-description="Niri (Wayland)" \
  long-description="Niri: A scrollable-tiling Wayland compositor. Instead of arranging windows in a fixed grid, Niri places them in an infinite horizontal strip that you scroll through, similar to a panoramic workspace. It is well-suited for keyboard-driven workflows and users who prefer automatic window tiling without manual layout management." \
  spdx-identifiers="GPL-3.0-or-later" \
  available="`has-gpu-render-node`" \
  default-value=#false {
    arch-packages "niri-git" \
                  "xwayland-satellite" \
                  "swaybg" \
                  "monique" \
                  "niri-settings-git"
    login-commands "systemctl --user stop niri.service 2>/dev/null"
    files "/usr/lib/ditana/start-niri-greetd" \
          "/usr/share/ditana/wayland-sessions/niri-ditana.desktop" \
          \ // === Niri config ===
          "/etc/skel/.config/niri/config.kdl" \
          "/usr/share/slick-greeter/badges/niri.svg" \
          \ // === NVIDIA Niri fix ===
          "/etc/nvidia/nvidia-application-profiles-rc.d/50-limit-free-buffer-pool-in-wayland-compositors.json"
    early-chroot-script \
      \ // Patch the keyboard repeat values in the niri config.
      #"sed -i -E "s|(repeat-delay[[:space:]]+)[0-9]+|\1${KEYBOARD_DELAY}|" /etc/skel/.config/niri/config.kdl"# \
      #"sed -i -E "s|(repeat-rate[[:space:]]+)[0-9]+|\1${KEYBOARD_RATE}|" /etc/skel/.config/niri/config.kdl"#
  }
- name="install-wayland" \
  default-value="`install-niri OR install-wayfire`" {
    files \ // === Waybar config ===
          "/etc/skel/.config/waybar/config.jsonc" \
          "/etc/skel/.config/waybar/style.css" \
          \ // === nwg-launchers config ===
          "/etc/skel/.config/nwg-launchers/nwggrid/terminal" \
          "/etc/skel/.config/nwg-launchers/nwgbar/bar.json"
    arch-packages "uwsm" \
                  "xdg-desktop-portal-gtk" \
                  "wayland-display-info" \
                  "wayland-font-dpi" \
                  "pacseek" \ // we link pacseek in the waybar config. For XFCE, it is linked only if it’s there (which it usually is, because install-pacman-core-tools is default)
                  "rofi" \
                  "wl-clipboard" \
                  "waybar" \
                  "nwg-launchers" \
                  "swaylock" \
                  "hyprpolkitagent" \
                  "mako"
  }
- name="install-waybar-display-scale" \
  default-value="`install-wayland`" {
    files "/usr/lib/systemd/user/waybar-display-scale.service" \
          "/usr/lib/ditana/waybar-display-scale"
    chroot-script "systemctl --global enable waybar-display-scale.service"
  }

// Terminal emulator philosophy: Ditana follows "Write programs that do
// one thing and do it well" (Doug McIlroy). The terminal emulates a
// terminal; tabs, panes, layouts, and session persistence are delegated
// to zellij, which is installed by default. This gives users rich
// multiplexing that works identically across emulators, hosts, and SSH
// sessions.
//
// A single default must be configured via xdg-terminal-exec and
// $TERMINAL, so there is no per-DE differentiation. Two emulators ship
// depending on the installed desktop stack:
//
//   - foot:      Wayland-native, default when only Wayland compositors
//                (Wayfire, Niri) are installed. Beyond Wayland being
//                the designated X11 successor, foot provides practical
//                features that upstream Alacritty intentionally omits.
//                  * OSC 133 semantic prompt markers — jump between
//                    prompts in scrollback, select full command output.
//                    Ditana ships shell hooks in /etc/skel/.shellrc
//                    that emit these markers in bash and zsh, scoped
//                    to foot via $TERM / $TERMINAL, because Starship
//                    does not emit OSC 133 natively.
//                  * OSC 9 / OSC 777 desktop notifications — any shell
//                    script or CLI tool can raise "build finished"
//                    style alerts with a single printf, no notify-send
//                    dependency, no D-Bus plumbing.
//                  * Sixel graphics — inline image previews in TUIs
//                    such as yazi, lf, gnuplot, matplotlib.
//                  * Server/daemon mode (foot --server) — near-instant
//                    window spawn, noticeable under tiling compositors
//                    where terminals are opened frequently.
//                  * Very small memory footprint per instance.
//
//   - alacritty: GPU-accelerated, works on both X11 and Wayland.
//                Becomes the default as soon as XFCE is part of the
//                installation, since foot is Wayland-only. Alacritty
//                explicitly declines tabs, panes, graphics protocols,
//                ligatures, and most OSC extensions as a design
//                principle — delegating to external tools. This keeps
//                the emulator layer minimal and makes it a clean
//                counterpart to zellij on both display servers.

- name="install-foot" \
  default-value="`install-wayland AND NOT install-xfce`" { // alacritty wins if one of the installed DEs is XFCE (we need to have a single default, because we use xdg-terminals)
    arch-packages "foot" \
                  "libnotify" \
                  "xdg-terminal-exec-git"
    files "/etc/skel/.config/foot/foot.ini"
    chroot-script "systemctl --global enable foot-server.service" \
                  "mkdir -p /etc/xdg" \
                  "echo foot.desktop >/etc/xdg/xdg-terminals.list" \
                  "sed -i '/^TERMINAL=/d' /etc/environment" \
                  "echo TERMINAL=foot >> /etc/environment"
  }
  
- name="install-alacritty" \
  default-value="`install-xfce`" {
    arch-packages "alacritty" \
                  "xdg-terminal-exec-git"
    chroot-script "mkdir -p /etc/xdg" \
                  "echo Alacritty.desktop >/etc/xdg/xdg-terminals.list" \
                  "sed -i '/^TERMINAL=/d' /etc/environment" \
                  "echo TERMINAL=alacritty >> /etc/environment"
  }
  
